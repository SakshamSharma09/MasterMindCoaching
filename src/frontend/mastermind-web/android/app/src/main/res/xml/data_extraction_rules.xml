<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Do not allow cloud backup on Android 12+ -->
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>

    <!-- Do not allow device-to-device transfer backup on Android 12+ -->
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
